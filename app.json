{
  "expo": {
    "name": "Roomly",
    "slug": "roomly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#e8edf2"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fatkoou.roomly"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#e8edf2"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-web-browser"
    ]
  }
}
