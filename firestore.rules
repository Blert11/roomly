// Paste this into Firebase Console → Firestore Database → Rules.
// Replace ALL existing rules, then click "Publish".
//
// Covers: listings, favorites, users, conversations, messages.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── Listings ──────────────────────────────────────────────
    // Public read (anyone can browse). Only the owner can mutate.
    match /listings/{listingId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.ownerId);
    }

    // ── Favorites ─────────────────────────────────────────────
    // Doc id pattern: {userId}_{listingId}. Each doc has a userId field.
    // A user can only read/write their own favorites.
    match /favorites/{favoriteId} {
      allow read:   if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // ── Users ────────────────────────────────────────────────
    // Anyone signed in can read another user's profile (display name, phone,
    // photo, push token). Only the user themselves can write.
    match /users/{userId} {
      allow read:  if isSignedIn();
      allow write: if isOwner(userId);
    }

    // ── Conversations ────────────────────────────────────────
    // NOTE: Read is intentionally loose (any signed-in user).
    // Firestore's LIST rule engine can't always infer that a query using
    // `where('participantIds', 'array-contains', auth.uid)` satisfies a
    // rule like `auth.uid in resource.data.participantIds`, so strict
    // rules cause permission-denied on legitimate inbox queries. We trust
    // the app code to always include the array-contains filter.
    match /conversations/{conversationId} {
      allow read: if isSignedIn();

      // Create: caller must be one of the two participants.
      allow create: if isSignedIn()
        && request.resource.data.participantIds.size() == 2
        && request.auth.uid in request.resource.data.participantIds;

      // Update: only existing participants can update.
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participantIds;

      allow delete: if false;

      // ── Messages subcollection ─────────────────────────────
      match /messages/{messageId} {
        allow read: if isSignedIn();

        // Sender must be the signed-in user.
        allow create: if isSignedIn()
          && request.resource.data.senderId == request.auth.uid;

        allow update, delete: if false;
      }
    }
  }
}
